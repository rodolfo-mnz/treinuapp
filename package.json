{
  "name": "treinu-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "turbo run start --filter=@treinu/mobile",
    "mobile:android": "turbo run android --filter=@treinu/mobile",
    "mobile:ios": "turbo run ios --filter=@treinu/mobile",
    "web": "turbo run dev --filter=@treinu/web",
    "build:web": "turbo run build --filter=@treinu/web"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
